{
  "openapi": "3.0.0",
  "info": {
    "title": "Stripe Accounts Contract (Focused)",
    "version": "2024-06-20",
    "description": "Minimal contract spec covering only the GET /v1/accounts endpoint, used for Specmatic contract test mode."
  },
  "servers": [
    { "url": "http://localhost:3000" }
  ],
  "paths": {
    "/v1/accounts": {
      "get": {
        "operationId": "GetV1Accounts",
        "summary": "List connected accounts",
        "description": "Returns a list of accounts connected to your platform via Connect.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "A limit on the number of objects to be returned (1-100).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100 },
            "examples": {
              "bad_limit": {
                "summary": "Invalid limit of 0 triggers a 400",
                "value": 0
              }
            }
          },
          {
            "name": "starting_after",
            "in": "query",
            "required": false,
            "description": "A cursor for use in pagination (object ID to start after).",
            "schema": { "type": "string" }
          },
          {
            "name": "ending_before",
            "in": "query",
            "required": false,
            "description": "A cursor for use in pagination (object ID to end before).",
            "schema": { "type": "string" }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "description": "Bearer token for authentication. Send 'Bearer invalid_key_12345' to trigger a 401.",
            "schema": { "type": "string" },
            "examples": {
              "no_auth": {
                "summary": "Invalid Bearer token triggers a 401",
                "value": "Bearer invalid_key_12345"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of Account objects.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountList" }
              }
            }
          },
          "400": {
            "description": "Bad request — e.g. invalid parameter value.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "bad_limit": {
                    "summary": "limit=0 is outside the allowed range [1, 100]",
                    "value": {
                      "error": {
                        "type": "invalid_request_error",
                        "message": "Invalid integer: 0 is not within the allowed range [1, 100].",
                        "code": "parameter_invalid_integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "no_auth": {
                    "summary": "The provided API key is not valid",
                    "value": {
                      "error": {
                        "type": "invalid_request_error",
                        "message": "No such API key: Bearer invalid_key_12345.",
                        "code": "api_key_missing"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccountList": {
        "type": "object",
        "required": ["object", "data", "has_more", "url"],
        "properties": {
          "object": {
            "type": "string",
            "enum": ["list"],
            "description": "String representing the object's type."
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Account" },
            "description": "A list of Account objects."
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more items beyond this list."
          },
          "url": {
            "type": "string",
            "description": "The URL for this list."
          }
        }
      },
      "Account": {
        "type": "object",
        "required": ["id", "object"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the account."
          },
          "object": {
            "type": "string",
            "enum": ["account"],
            "description": "String representing the object's type, always 'account'."
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "The email address associated with the account."
          },
          "type": {
            "type": "string",
            "enum": ["custom", "express", "standard", null],
            "nullable": true,
            "description": "The Stripe account type."
          },
          "created": {
            "type": "integer",
            "description": "Time at which the account was created (Unix timestamp)."
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "The account's country."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["type", "message"],
            "properties": {
              "type": { "type": "string" },
              "message": { "type": "string" },
              "code": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
